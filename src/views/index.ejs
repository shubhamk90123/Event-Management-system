<!DOCTYPE html>
<html lang="en">

    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Event Management</title>
        <link rel="stylesheet" href="/css/output.css">

        <style>
            .fade-in {
                animation: fadeIn 0.8s ease forwards;
            }

            @keyframes fadeIn {
                from {
                    opacity: 0;
                    transform: translateY(20px);
                }

                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }
        </style>
    </head>

    <body
        class="bg-gradient-to-br from-blue-50 via-white to-gray-100 min-h-screen flex items-center justify-center px-4">


        <div class="absolute w-72 h-72 bg-blue-200 rounded-full blur-3xl opacity-30 top-10 left-10"></div>
        <div class="absolute w-72 h-72 bg-blue-300 rounded-full blur-3xl opacity-20 bottom-10 right-10"></div>

        <div
            class="relative bg-white/70 backdrop-blur-xl p-10 rounded-3xl shadow-xl text-center max-w-md w-full border border-white/40 fade-in">

            <h1 class="text-3xl font-semibold text-gray-800 mb-3 tracking-tight">
                Event Management
            </h1>


            <p class="text-gray-500 text-sm mb-8 leading-relaxed">
                Manage your events with a modern, streamlined experience.
            </p>

            <div class="flex flex-col space-y-4">

                <a href="/login" class="w-full bg-blue-600 text-white py-3 rounded-xl font-medium transition duration-300 shadow-md 
                hover:bg-blue-700 hover:shadow-xl hover:-translate-y-1">
                    Log In
                </a>

                <a href="/signup" class="w-full bg-white/80 text-gray-700 py-3 rounded-xl font-medium border border-gray-200 
                backdrop-blur transition duration-300 hover:bg-white hover:shadow-md">
                    Create Account
                </a>

            </div>


            <p class="text-xs text-gray-400 mt-8">
                Designed for simplicity • Built for performance
            </p>

        </div>


    </body>

</html>