<!DOCTYPE html>
<html lang="en">

    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Admin Dashboard - Event Management</title>
        <link rel="stylesheet" href="/css/output.css">
    </head>

    <body class="bg-linear-to-br from-gray-100 to-gray-200 min-h-screen p-6 flex justify-center items-start">

        <div class="bg-white p-10 rounded-2xl shadow-xl w-full max-w-5xl mt-6 border border-gray-100">

            <h2 class="text-3xl font-bold text-center text-gray-800 mb-10 tracking-tight">
                Event Management Dashboard
            </h2>

            <div class="overflow-x-auto mb-10 rounded-lg border border-gray-200">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-gray-100">
                            <th class="p-4 font-semibold text-gray-800 border border-gray-200">Event Name</th>
                            <th class="p-4 font-semibold text-gray-800 border border-gray-200">Date</th>
                            <th class="p-4 font-semibold text-gray-800 border border-gray-200">Location</th>

                            <th class="p-4 font-semibold text-gray-800 border border-gray-200 text-center">Actions</th>
                        </tr>
                    </thead>


                    <tbody>
                        <% if (typeof events !=='undefined' && events.length> 0) { %>
                            <% events.forEach(event=> { %>
                                <tr class="hover:bg-gray-50 transition">
                                    <td class="p-4 text-gray-800 border border-gray-200">
                                        <%= event.name %>
                                    </td>
                                    <td class="p-4 text-gray-600 border border-gray-200">
                                        <%= new Date(event.date).toLocaleDateString('en-GB', { day: '2-digit' ,
                                            month: 'short' , year: 'numeric' }) %>
                                    </td>
                                    <td class="p-4 text-gray-600 border border-gray-200">
                                        <%= event.location %>
                                    </td>

                                    <td class="p-4 flex gap-2 justify-center text-center border border-gray-200">
                                        <a href="/admin-dashboard?eventId=<%= event._id %>"
                                            class="text-white py-1.5 px-4 rounded border border-blue-700 shadow-sm hover:bg-blue-700 transition <%= selectedEventId && selectedEventId.toString() === event._id.toString() ? 'bg-blue-700' : 'bg-blue-600' %>">
                                            View Users
                                        </a>
                                        <form method="POST" action="/delete-event/<%= event._id %>">
                                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                            <button type="submit"
                                                class="bg-red-600 text-white py-1.5 px-4 rounded hover:bg-red-700 transition">
                                                Delete
                                            </button>
                                        </form>


                                    </td>
                                </tr>
                                <% }) %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="5"
                                                class="p-8 text-center text-gray-500 border border-gray-200">No events
                                                currently available.</td>
                                        </tr>
                                        <% } %>
                    </tbody>
                </table>
            </div>
            <div class="mb-6">
                <h3 class="text-xl font-semibold text-gray-800 mb-4">
                    Registered Users for each event
                </h3>

                <div class="bg-gray-50 rounded-lg border border-gray-200 divide-y">
                    <% if (selectedEvent && selectedEvent.attendees.length> 0) { %>
                        <% selectedEvent.attendees.forEach(user=> { %>
                            <div class="p-4">
                                Name : <%= user.name %> <br>Email: <%= user.email %>
                            </div>
                            <% }) %>
                                <% } else { %>
                                    <div class="p-4 text-gray-400">No users registered yet.</div>
                                    <% } %>

                </div>
            </div>

            <div class="text-center mt-10">
                <form action="/logout" method="POST" class="inline">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit"
                        class="text-red-500 cursor-pointer font-medium hover:text-red-600 transition mx-2">Log
                        Out</button>
                </form>

                <form action="/create-event" method="GET" class="inline">
                    <button type="submit"
                        class="text-blue-600 font-medium hover:text-blue-700 transition cursor-pointer mx-2">Create
                        Event</button>
                </form>
            </div>

        </div>

    </body>

</html>