<!DOCTYPE html>
<html lang="en">

    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Available Events - Event Management</title>
        <link rel="stylesheet" href="/css/output.css">
    </head>

    <body class="bg-gray-100 min-h-screen p-8 flex justify-center items-start pt-16">
        <div class="bg-white p-8 rounded-lg shadow-lg w-full max-w-5xl">
            <h2 class="text-3xl font-bold text-center text-gray-800 mb-8">Available Events</h2>

            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse border border-gray-200">
                    <thead>
                        <tr class="bg-gray-100">
                            <th class="p-4 font-semibold text-gray-800 border border-gray-200">Event Name</th>
                            <th class="p-4 font-semibold text-gray-800 border border-gray-200">Date</th>
                            <th class="p-4 font-semibold text-gray-800 border border-gray-200">Location</th>
                            <th class="p-4 font-semibold text-gray-800 border border-gray-200">Details</th>
                            <th class="p-4 font-semibold text-gray-800 border border-gray-200 text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (typeof events !=='undefined' && events.length> 0) { %>
                            <% events.forEach(event=> { %>
                                <tr class="hover:bg-gray-50 transition">
                                    <td class="p-4 text-gray-800 border border-gray-200">
                                        <%= event.name %>
                                    </td>
                                    <td class="p-4 text-gray-600 border border-gray-200">
                                        <%= new Date(event.date).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                                    </td>
                                    <td class="p-4 text-gray-600 border border-gray-200">
                                        <%= event.location %>
                                    </td>
                                    <td class="p-4 text-gray-600 border border-gray-200">
                                        <%= event.details %>
                                    </td>
                                    <td class="p-4 text-center border border-gray-200">
                                        <form method="POST" action="/book-event/<%= event._id %>">
                                            <button type="submit"
                                                class="bg-blue-600 text-white py-1.5 px-4 rounded border border-blue-700 shadow-sm hover:bg-blue-700 transition">
                                                Book Now
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                                <% }) %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="5"
                                                class="p-8 text-center text-gray-500 border border-gray-200">No events
                                                currently available.</td>
                                        </tr>
                                        <% } %>
                    </tbody>
                </table>
            </div>

            <form class="mt-8 text-center" method="POST" action="/logout">
                <button type="submit"
                    class="bg-blue-600 text-white py-1.5 px-4 rounded mt-8  border-gray-300 shadow-sm hover:bg-red-600 transition">Log
                    Out</button>
            </form>
        </div>
    </body>

</html>