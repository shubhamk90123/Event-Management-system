<!DOCTYPE html>
<html lang="en">

  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Feedback Application</title>
    <link rel="stylesheet" href="/css/output.css">
  </head>

  <body
    class="m-0 min-h-screen font-['Segoe_UI',Tahoma,Geneva,Verdana,sans-serif] bg-[linear-gradient(135deg,#e3f2fd_0%,#f8fbff_45%,#fff3e0_100%)] text-[#1f2937]">
    <main class="min-h-screen grid place-items-center p-6">
      <section
        class="w-full max-w-[520px] text-center bg-white border border-[#dbeafe] rounded-[16px] pt-[36px] pb-[36px] px-[28px] shadow-[0_12px_30px_rgba(37,99,235,0.12)]">
        <p class="m-0 text-[72px] leading-none font-bold text-[#2563eb]">404</p>
        <h1 class="mt-[12px] mx-0 mb-[10px] text-[34px]">Page Not Found</h1>
        <p class="m-0 mb-[24px] text-[16px] leading-[1.6] text-[#4b5563]">The page you are looking for does not exist or
          may have been moved.</p>
        <a href="/"
          class="inline-block no-underline bg-[#2563eb] text-white py-[10px] px-[18px] rounded-[8px] font-semibold border border-[#1d4ed8] transition-all duration-200 hover:-translate-y-px hover:shadow-[0_8px_16px_rgba(37,99,235,0.25)] active:translate-y-0">Back
          To Home</a>
      </section>
    </main>
  </body>

</html>