<!DOCTYPE html>
<html lang="en">

    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Create Event</title>
        <link rel="stylesheet" href="/css/output.css">
    </head>

    <body class="min-h-screen bg-gray-100 flex items-center justify-center p-4">

        <div class="w-full max-w-md bg-white p-6 rounded-xl shadow">

            <h2 class="text-2xl font-bold text-gray-800 mb-6 text-center">Create Event</h2>

            <form action="/create-event" method="POST" class="space-y-4">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                <div>
                    <label class="block text-sm text-gray-600 mb-1">Event Name</label>
                    <input type="text" name="name" required
                        class="w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500"
                        placeholder="Event name" />
                </div>

                <div>
                    <label class="block text-sm text-gray-600 mb-1">Date</label>
                    <input type="date" name="date" required
                        class="w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" />
                </div>

                <div>
                    <label class="block text-sm text-gray-600 mb-1">Location</label>
                    <input type="text" name="location" required
                        class="w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500"
                        placeholder="Location" />
                </div>

                <div>
                    <label class="block text-sm text-gray-600 mb-1">Details</label>
                    <textarea name="details" rows="3" required
                        class="w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500"
                        placeholder="Event details"></textarea>
                </div>

                <div class="flex justify-between items-center pt-2">
                    <a href="/admin-dashboard" class="text-sm text-gray-500">Cancel</a>

                    <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700">
                        Create
                    </button>
                </div>

            </form>

        </div>

    </body>

</html>